{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Start Local Web Server (Python 5500)",
      "type": "debugpy",
      "request": "launch",
      "module": "http.server",
      "args": [
        "5500"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Open Site in Edge (http://localhost:5500)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5500",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Run & Test Website (Server + Edge)",
      "configurations": [
        "Start Local Web Server (Python 5500)",
        "Open Site in Edge (http://localhost:5500)"
      ],
      "stopAll": true
    }
  ]
}
